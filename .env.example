# Copy this file to .env and fill in your values.
# .env is in .gitignore and must never be committed.

# Deribit API credentials
# Paper (testnet):  https://test.deribit.com  → Account → API Management
# Live:             https://www.deribit.com   → Account → API Management
#
# Required scopes: read, trade  (trade only needed for order placement)
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=

# Alert recipients (leave blank to disable)
ALERT_EMAIL=
TELEGRAM_TOKEN=
TELEGRAM_CHAT=
